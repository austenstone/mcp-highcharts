{
  "colors": [
    "#006edb",
    "#30a147",
    "#eb670f",
    "#ce2c85",
    "#b88700",
    "#df0c24",
    "#894ceb",
    "#9d615c",
    "#179b9b",
    "#808fa3"
  ],
  "chart": {
    "backgroundColor": "transparent",
    "animation": false,
    "style": {
      "fontFamily": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
      "fontSize": "12px",
      "color": "#e5e7eb"
    },
    "spacing": [4, 0, 4, 0]
  },
  "title": {
    "style": {
      "color": "#e5e7eb",
      "fontSize": "16px",
      "fontWeight": "600"
    }
  },
  "subtitle": {
    "style": {
      "color": "#9ca3af",
      "fontSize": "12px"
    }
  },
  "xAxis": {
    "tickWidth": 0,
    "lineWidth": 1,
    "crosshair": {
      "color": "rgba(139, 148, 158, 0.5)",
      "width": 1,
      "dashStyle": "Dash"
    },
    "gridLineColor": "rgba(139, 148, 158, 0.15)",
    "gridLineDashStyle": "Dash",
    "lineColor": "rgba(139, 148, 158, 0.4)",
    "labels": {
      "style": {
        "color": "#d1d5db",
        "fontSize": "11px"
      }
    },
    "title": {
      "style": {
        "color": "#9ca3af",
        "fontSize": "11px"
      }
    }
  },
  "yAxis": {
    "tickWidth": 0,
    "lineWidth": 0,
    "gridLineColor": "rgba(139, 148, 158, 0.15)",
    "gridLineDashStyle": "Dash",
    "labels": {
      "style": {
        "color": "#d1d5db",
        "fontSize": "11px"
      }
    },
    "title": {
      "style": {
        "color": "#9ca3af",
        "fontSize": "11px"
      }
    }
  },
  "legend": {
    "itemStyle": {
      "fontSize": "12px",
      "font": "system-ui",
      "color": "#d1d5db"
    },
    "align": "left",
    "verticalAlign": "top",
    "x": -8,
    "y": -12,
    "itemHoverStyle": {
      "color": "#60a5fa"
    }
  },
  "tooltip": {
    "backgroundColor": "#1f2937",
    "borderColor": "#374151",
    "borderWidth": 1,
    "borderRadius": 6,
    "shadow": false,
    "shared": true,
    "useHTML": true,
    "style": {
      "color": "#e5e7eb",
      "fontFamily": "system-ui",
      "fontSize": "12px"
    }
  },
  "colorAxis": {
    "minColor": "#2d333b",
    "maxColor": "#006edb",
    "labels": {
      "style": {
        "color": "#d1d5db"
      }
    }
  },
  "responsive": {
    "rules": [
      {
        "condition": { "maxWidth": 400 },
        "chartOptions": {
          "legend": { "enabled": false },
          "yAxis": { "title": { "text": "" } }
        }
      }
    ]
  },
  "navigation": {
    "buttonOptions": {
      "enabled": false
    }
  },
  "exporting": {
    "fallbackToExportServer": false
  },
  "plotOptions": {
    "series": {
      "animation": false,
      "marker": {
        "enabled": false,
        "states": {
          "hover": { "enabled": true, "radius": 6, "lineWidth": 2, "lineColor": "#ffffff" }
        }
      }
    },
    "line": { "lineWidth": 2 },
    "spline": { "lineWidth": 2 },
    "area": { "fillOpacity": 0.15, "lineWidth": 2 },
    "scatter": {
      "lineWidth": 0,
      "marker": {
        "enabled": true,
        "radius": 8,
        "symbol": "circle",
        "lineWidth": 1,
        "lineColor": "rgba(255, 255, 255, 0.3)",
        "states": {
          "hover": { "enabled": true, "radius": 10, "lineWidth": 2, "lineColor": "#ffffff" }
        }
      }
    },
    "networkgraph": {
      "layoutAlgorithm": { "enableSimulation": false },
      "marker": { "enabled": true, "radius": 12 },
      "dataLabels": {
        "enabled": true,
        "color": "#e5e7eb",
        "style": { "fontSize": "11px", "textOutline": "none" }
      }
    },
    "column": {
      "borderColor": "transparent",
      "borderWidth": 1.5
    },
    "bar": {
      "borderColor": "transparent",
      "borderWidth": 1.5
    },
    "pie": {
      "borderWidth": 0,
      "dataLabels": {
        "color": "#e5e7eb",
        "style": { "fontSize": "11px", "textOutline": "none" }
      }
    }
  },
  "credits": {
    "enabled": false
  }
}
