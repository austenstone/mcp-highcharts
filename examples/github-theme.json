{
  "colors": [
    "#006edb",
    "#30a147",
    "#eb670f",
    "#ce2c85",
    "#b88700",
    "#df0c24",
    "#894ceb",
    "#9d615c",
    "#179b9b",
    "#808fa3"
  ],
  "accessibility": {
    "keyboardNavigation": {
      "order": ["legend", "series"]
    }
  },
  "chart": {
    "backgroundColor": "transparent",
    "animation": false,
    "spacing": [4, 0, 4, 0],
    "style": {
      "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans', Helvetica, Arial, sans-serif",
      "fontSize": "12px"
    }
  },
  "title": {
    "style": {
      "fontSize": "16px",
      "fontWeight": "600"
    }
  },
  "subtitle": {
    "style": {
      "fontSize": "12px"
    }
  },
  "legend": {
    "itemStyle": {
      "fontSize": "12px"
    },
    "align": "left",
    "verticalAlign": "top",
    "x": -8,
    "y": -12
  },
  "navigation": {
    "buttonOptions": {
      "enabled": false
    }
  },
  "exporting": {
    "fallbackToExportServer": false
  },
  "plotOptions": {
    "series": {
      "animation": false
    },
    "spline": {
      "animation": false
    },
    "bar": {
      "borderWidth": 1
    },
    "column": {
      "borderWidth": 1
    }
  },
  "xAxis": {
    "tickWidth": 0,
    "lineWidth": 1,
    "gridLineDashStyle": "Dash"
  },
  "yAxis": {
    "tickWidth": 0,
    "lineWidth": 0,
    "gridLineDashStyle": "Dash",
    "stackLabels": {
      "style": {
        "fontSize": "12px"
      }
    }
  },
  "credits": {
    "enabled": false
  }
}
